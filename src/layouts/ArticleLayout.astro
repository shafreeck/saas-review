---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import VerdictBox from '../components/VerdictBox.astro';
import AdSlot from '../components/AdSlot.astro';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const {
  title,
  description,
  category,
  pubDate,
  updatedDate,
  author,
  verdict,
  picks,
  toolsTested,
} = article.data;

const slug = article.id.replace(/\.mdx$/, '');
const path = `/articles/${slug}/`;
const site = Astro.site ?? new URL('https://toolverdict.dev/');

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

const jsonLd: object[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description,
    author: { '@type': 'Organization', name: author },
    publisher: { '@type': 'Organization', name: 'ToolVerdict' },
    datePublished: pubDate.toISOString(),
    ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
    mainEntityOfPage: new URL(path, site).href,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', site).href },
      { '@type': 'ListItem', position: 2, name: 'Reviews', item: new URL('/articles/', site).href },
      { '@type': 'ListItem', position: 3, name: title, item: new URL(path, site).href },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Review',
    itemReviewed: { '@type': 'SoftwareApplication', name: verdict.winner },
    reviewRating: { '@type': 'Rating', ratingValue: verdict.score, bestRating: 10 },
    author: { '@type': 'Organization', name: author },
    reviewBody: verdict.summary,
  },
];
---

<BaseLayout
  title={`${title} · ToolVerdict`}
  description={description}
  path={path}
  ogType="article"
  jsonLd={jsonLd}
>
  <article class="article container">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="crumb-sep" aria-hidden="true">/</span>
      <a href="/articles/">Reviews</a>
      <span class="crumb-sep" aria-hidden="true">/</span>
      <span class="crumb-current">{title}</span>
    </nav>

    <header class="article-head">
      <div class="head-tags">
        <span class="mono-tag">{category}</span>
        {
          typeof toolsTested === 'number' && (
            <span class="mono-tag tag-green">{toolsTested} tools tested</span>
          )
        }
      </div>
      <h1 class="article-title">{title}</h1>
      <p class="article-dek">{description}</p>
      <div class="article-meta">
        <span>By {author}</span>
        <span class="meta-dot" aria-hidden="true">·</span>
        <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
        {
          updatedDate && (
            <>
              <span class="meta-dot" aria-hidden="true">·</span>
              <span class="meta-updated">Updated {fmt(updatedDate)}</span>
            </>
          )
        }
      </div>
    </header>

    {
      picks.length > 0 && (
        <div class="quickpicks" data-reveal>
          <span class="qp-head">Quick picks</span>
          <div class="qp-row">
            {picks.map((p) => (
              <div class="qp-chip">
                <span class="qp-label">{p.label}</span>
                <span class="qp-tool">{p.tool}</span>
                <span class="qp-score">{p.score.toFixed(1)}</span>
              </div>
            ))}
          </div>
        </div>
      )
    }

    <VerdictBox score={verdict.score} winner={verdict.winner} label={verdict.label}>
      <p>{verdict.summary}</p>
    </VerdictBox>

    <div class="prose">
      <slot />
    </div>

    <AdSlot format="in-article" />

    <footer class="article-foot">
      <a class="btn btn-ghost" href="/articles/">← All reviews</a>
      <p class="foot-note">
        Prices verified at publication. Some outbound links may be affiliate links — verdicts
        are never for sale.
      </p>
    </footer>
  </article>
</BaseLayout>

<style>
  .article {
    padding-block: 2.5rem 1rem;
  }
  .crumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 1.8rem;
  }
  .crumbs a {
    text-decoration: none;
    color: var(--green-deep);
  }
  .crumbs a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .crumb-current {
    max-width: 32ch;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .article-head {
    max-width: 820px;
  }
  .head-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.1rem;
  }
  .tag-green {
    background: var(--green-tint);
    border-color: var(--green-deep);
    color: var(--green-deep);
  }
  .article-title {
    font-size: clamp(2rem, 4.6vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .article-dek {
    margin-top: 1rem;
    font-size: 1.12rem;
    color: var(--ink-soft);
    max-width: 62ch;
  }
  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-top: 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
  }
  .meta-updated {
    color: var(--green-deep);
  }
  .quickpicks {
    margin: 2.25rem 0 0;
    border: var(--border);
    background: var(--card);
    box-shadow: var(--shadow-hard);
  }
  .qp-head {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: var(--ink);
    color: var(--paper);
    padding: 0.5rem 1rem;
  }
  .qp-row {
    display: flex;
    gap: 0.75rem;
    padding: 1rem;
    overflow-x: auto;
  }
  .qp-chip {
    flex: none;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 170px;
    padding: 0.7rem 0.9rem;
    border: 1.5px solid var(--ink);
    background: var(--paper);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .qp-chip:hover {
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--ink);
  }
  .qp-label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--green-deep);
  }
  .qp-tool {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.02rem;
  }
  .qp-score {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--ink-soft);
  }
  .article-foot {
    margin-top: 3rem;
    padding-top: 1.6rem;
    border-top: var(--border);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }
  .foot-note {
    font-size: 0.82rem;
    color: var(--ink-soft);
    max-width: 60ch;
  }
</style>
