---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Verdict not found · ToolVerdict"
  description="This page does not exist. Return to the ToolVerdict archive."
  noindex
>
  <section class="container nf">
    <span class="nf-code">404</span>
    <h1 class="nf-title">Verdict not found.</h1>
    <p class="nf-sub">
      This page was either never published, or it failed the review process. Either way, it's not
      here.
    </p>
    <div class="nf-cta">
      <a class="btn" href="/">Back to the front page</a>
      <a class="btn btn-ghost" href="/articles/">Browse the archive</a>
    </div>
  </section>
</BaseLayout>

<style>
  .nf {
    padding-block: clamp(4rem, 10vw, 7rem);
    text-align: left;
    max-width: 640px;
  }
  .nf-code {
    font-family: var(--font-mono);
    font-size: clamp(4rem, 10vw, 6.5rem);
    font-weight: 600;
    line-height: 1;
    color: var(--green);
    display: block;
  }
  .nf-title {
    font-size: clamp(1.9rem, 4vw, 2.6rem);
    font-weight: 700;
    margin-top: 0.8rem;
  }
  .nf-sub {
    margin-top: 0.8rem;
    color: var(--ink-soft);
    max-width: 44ch;
  }
  .nf-cta {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    margin-top: 1.8rem;
  }
</style>
