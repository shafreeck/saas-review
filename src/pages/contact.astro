---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact · ToolVerdict"
  description="Send ToolVerdict corrections, tool tips, and vendor updates. How to reach the editorial desk."
  path="/contact/"
>
  <section class="container contact">
    <span class="mono-tag">Contact</span>
    <h1 class="contact-title">Talk to the editorial desk.</h1>

    <div class="contact-grid">
      <div class="contact-card" data-reveal>
        <span class="cc-head">Corrections &amp; price updates</span>
        <p>
          A price changed? A feature died? Send the article link plus a source (vendor pricing
          page, changelog, screenshot). Verified corrections are applied within 48 hours and
          logged.
        </p>
        <a class="btn" href="mailto:corrections@toolverdict.dev">Send a correction</a>
      </div>

      <div class="contact-card" data-reveal>
        <span class="cc-head">Tool tips</span>
        <p>
          Know a tool that deserves a trial? Tell us what it does, who it's for, and why the
          current alternatives fall short. Tips that fit the queue get tested like everything
          else.
        </p>
        <a class="btn btn-ghost" href="mailto:tips@toolverdict.dev">Suggest a tool</a>
      </div>

      <div class="contact-card" data-reveal>
        <span class="cc-head">Vendors</span>
        <p>
          Vendors may point out factual errors in their coverage. What we don't do: sponsored
          placements, score adjustments, or pre-publication review. The verdict stands as
          published.
        </p>
        <a class="btn btn-ghost" href="mailto:vendors@toolverdict.dev">Vendor inquiries</a>
      </div>
    </div>

    <p class="contact-note">
      Note: email addresses on this page are placeholders until the domain is live — update them
      after purchase.
    </p>
  </section>
</BaseLayout>

<style>
  .contact {
    padding-block: 2.5rem 2rem;
  }
  .contact-title {
    font-size: clamp(2rem, 4.6vw, 3rem);
    font-weight: 700;
    margin-top: 1rem;
    max-width: 20ch;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2.2rem;
  }
  .contact-card {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: 1.4rem;
    border: var(--border);
    background: var(--card);
    box-shadow: var(--shadow-hard);
    transition: transform 0.16s ease, box-shadow 0.16s ease;
  }
  .contact-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: var(--shadow-lift);
  }
  .cc-head {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--green-deep);
  }
  .contact-card p {
    font-size: 0.93rem;
    color: var(--ink-soft);
    flex: 1;
  }
  .contact-card .btn {
    align-self: flex-start;
  }
  .contact-note {
    margin-top: 1.6rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--ink-soft);
  }
  @media (max-width: 860px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
